//@version=6
// =============================================================================
// Stimmungswechsel-Indikator  (Schritt 1: Farbwechsel + Extrem)
// =============================================================================
// Zweck dieser Datei:
//   Baustein 2 des Indikators. Es wird ab einem frei waehlbaren Startzeitpunkt
//   auf dem 2H-Heikin-Ashi-Frame nach STIMMUNGSWECHSELN gesucht.
//
//   Begriffe (Nutzer-Sprech):
//     - BLAUE Kerze  = bullish (close > open)
//     - ROTE  Kerze  = bearish (close < open)
//
//   Stimmungswechsel = Farbwechsel zweier aufeinanderfolgender 2H-Kerzen:
//     - BEARISCHER Wechsel: ROT folgt auf BLAU
//     - BULLISCHER Wechsel: BLAU folgt auf ROT
//
//   EXTREM = "highest/lowest out of four":
//     Es zaehlen die beiden Wechsel-Kerzen PLUS je eine Kerze LINKS und RECHTS
//     daneben (= 4 Kerzen). Fenster:  [ links , A , B , rechts ]
//       - A = erste Wechsel-Kerze, B = zweite Wechsel-Kerze
//       - bearischer Wechsel (A blau, B rot)  -> hoechstes High der 4 Kerzen
//       - bullischer Wechsel (A rot, B blau)  -> tiefstes  Low  der 4 Kerzen
//     Hinweis: Weil die Kerze RECHTS mitzaehlt, wird erst gezeichnet, wenn
//     diese abgeschlossen ist -> eine 2H-Kerze zusaetzliche Verzoegerung.
//
//   Pro Wechsel: waagerechte Linie am Extrem, 4 Kerzen (4 x 2H) nach rechts.
//
// Status: "ruhend" - nicht mit Webapp/Build verbunden. Vorlage fuer TradingView.
//
// -----------------------------------------------------------------------------
// ARCHITEKTUR / VERBINDLICHE SPEZIFIKATION  (Stand: 2026-06-26)
// -----------------------------------------------------------------------------
//   1) STARTZEITPUNKT per Chart-Klick (input.time, confirm=true). Davor: nichts.
//   2) GRUND-RECHEN-ZEITEINHEIT = 2H (Heikin Ashi), unabhaengig von der Chart-TF.
//   3) VISUALISIERUNG zeit-basiert (xloc.bar_time) -> korrekt auf jeder TF.
//
//   WICHTIG: Der History-Operator [1] INNERHALB von request.security ist mit
//   lookahead_off NICHT zuverlaessig. Deshalb holen wir nur ROHE 2H-Werte und
//   fuehren die letzten ABGESCHLOSSENEN 2H-Kerzen explizit chart-seitig mit.
//
//   BEKANNTE GRENZE: Voll praezise auf Chart-Zeiteinheiten <= 2H.
// =============================================================================

indicator("Stimmungswechsel 2H (HA)", overlay = true, max_lines_count = 500, max_labels_count = 500)

// -----------------------------------------------------------------------------
// Eingaben
// -----------------------------------------------------------------------------
startTime = input.time(timestamp("2024-01-01 00:00 +0000"), "Startzeitpunkt", confirm = true)

showStartMarker = input.bool(true,  "Startpunkt markieren",                 group = "Optik")
lineLenBars     = input.int(4,      "Linienlaenge (in 2H-Kerzen)", minval = 1, group = "Optik")
lineW           = input.int(2,      "Linienstaerke",      minval = 1, maxval = 5, group = "Optik")
colBull         = input.color(#2962ff, "Farbe bullischer Wechsel (blau)",   group = "Optik")
colBear         = input.color(#d50000, "Farbe bearischer Wechsel (rot)",    group = "Optik")
showDebug       = input.bool(false, "Debug-Label (Extreme je Wechsel)",     group = "Debug")

// -----------------------------------------------------------------------------
// Startpunkt-Marker (auf der jeweiligen Chart-Zeiteinheit)
// -----------------------------------------------------------------------------
isStartBar = time >= startTime and time[1] < startTime
if showStartMarker and isStartBar
    line.new(bar_index, low, bar_index, high, extend = extend.both, color = color.new(color.orange, 0), width = 1)
    label.new(bar_index, high, "Start", style = label.style_label_down, color = color.orange, textcolor = color.white, yloc = yloc.abovebar)

// -----------------------------------------------------------------------------
// Rohe 2H-Heikin-Ashi-Werte holen (NUR aktuelle Bar-Werte, kein [1] in security!)
// -----------------------------------------------------------------------------
ha2h = ticker.heikinashi(syminfo.tickerid)
[o2, c2, h2, l2, t2] = request.security(ha2h, "120",
     [open, close, high, low, time],
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

// -----------------------------------------------------------------------------
// Rollendes Fenster der letzten 4 ABGESCHLOSSENEN 2H-Kerzen
//   Index 0 = aelteste (links), 1 = A, 2 = B, 3 = neueste (rechts)
// -----------------------------------------------------------------------------
var array<float> oArr = array.new<float>()
var array<float> cArr = array.new<float>()
var array<float> hArr = array.new<float>()
var array<float> lArr = array.new<float>()
var array<int>   tArr = array.new<int>()

// Erste Chart-Kerze einer neuen 2H-Kerze -> vorige 2H-Kerze gerade abgeschlossen.
// Deren Endwerte per [1] auf CHART-Ebene (zuverlaessig).
isNew2H = not na(t2) and (na(t2[1]) or t2 != t2[1])

ms2H = 120 * 60 * 1000  // Millisekunden je 2H-Kerze

if isNew2H and not na(o2[1])
    array.push(oArr, o2[1])
    array.push(cArr, c2[1])
    array.push(hArr, h2[1])
    array.push(lArr, l2[1])
    array.push(tArr, t2[1])
    if array.size(oArr) > 4
        array.shift(oArr)
        array.shift(cArr)
        array.shift(hArr)
        array.shift(lArr)
        array.shift(tArr)

    if array.size(oArr) == 4
        // Wechsel-Kerzen sind A (Index 1) und B (Index 2); B ist die Wechselkerze
        aOpen  = array.get(oArr, 1)
        aClose = array.get(cArr, 1)
        bOpen  = array.get(oArr, 2)
        bClose = array.get(cArr, 2)
        bTime  = array.get(tArr, 2)

        aBlue = aClose > aOpen
        aRed  = aClose < aOpen
        bBlue = bClose > bOpen
        bRed  = bClose < bOpen

        // Extrem ueber alle 4 Kerzen (links, A, B, rechts)
        hiOfFour = math.max(math.max(array.get(hArr, 0), array.get(hArr, 1)), math.max(array.get(hArr, 2), array.get(hArr, 3)))
        loOfFour = math.min(math.min(array.get(lArr, 0), array.get(lArr, 1)), math.min(array.get(lArr, 2), array.get(lArr, 3)))

        canEval = not na(bTime) and bTime >= startTime

        // BEARISCHER Wechsel: A blau, B rot -> hoechstes High der 4 Kerzen
        if canEval and aBlue and bRed
            line.new(x1 = bTime, y1 = hiOfFour, x2 = bTime + lineLenBars * ms2H, y2 = hiOfFour,
                      xloc = xloc.bar_time, color = colBear, width = lineW)
            if showDebug
                label.new(bTime, hiOfFour, xloc = xloc.bar_time, yloc = yloc.price,
                      text = "BEAR hi4=" + str.tostring(hiOfFour, format.mintick) +
                             "\nL=" + str.tostring(array.get(hArr, 0), format.mintick) +
                             " A=" + str.tostring(array.get(hArr, 1), format.mintick) +
                             " B=" + str.tostring(array.get(hArr, 2), format.mintick) +
                             " R=" + str.tostring(array.get(hArr, 3), format.mintick),
                      style = label.style_label_down, color = colBear, textcolor = color.white, size = size.small)

        // BULLISCHER Wechsel: A rot, B blau -> tiefstes Low der 4 Kerzen
        if canEval and aRed and bBlue
            line.new(x1 = bTime, y1 = loOfFour, x2 = bTime + lineLenBars * ms2H, y2 = loOfFour,
                      xloc = xloc.bar_time, color = colBull, width = lineW)
            if showDebug
                label.new(bTime, loOfFour, xloc = xloc.bar_time, yloc = yloc.price,
                      text = "BULL lo4=" + str.tostring(loOfFour, format.mintick) +
                             "\nL=" + str.tostring(array.get(lArr, 0), format.mintick) +
                             " A=" + str.tostring(array.get(lArr, 1), format.mintick) +
                             " B=" + str.tostring(array.get(lArr, 2), format.mintick) +
                             " R=" + str.tostring(array.get(lArr, 3), format.mintick),
                      style = label.style_label_up, color = colBull, textcolor = color.white, size = size.small)
