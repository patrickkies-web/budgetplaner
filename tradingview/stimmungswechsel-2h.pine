//@version=6
// =============================================================================
// Stimmungswechsel-Indikator  (Schritt 1: Farbwechsel + Extrem)
// =============================================================================
// Zweck dieser Datei:
//   Baustein 2 des Indikators. Es wird ab einem frei waehlbaren Startzeitpunkt
//   auf dem 2H-Heikin-Ashi-Frame nach STIMMUNGSWECHSELN gesucht.
//
//   Begriffe (Nutzer-Sprech):
//     - BLAUE Kerze  = bullish (close > open)
//     - ROTE  Kerze  = bearish (close < open)
//
//   Stimmungswechsel = Farbwechsel zweier aufeinanderfolgender 2H-Kerzen:
//     - BEARISCHER Wechsel: ROT folgt auf BLAU
//     - BULLISCHER Wechsel: BLAU folgt auf ROT
//
//   Pro Wechsel:
//     1) Farbwechsel finden
//     2) das relevante EXTREM der beiden Kerzen bestimmen:
//          - bearischer Wechsel -> das HOEHERE High der beiden Kerzen
//          - bullischer Wechsel -> das TIEFERE  Low  der beiden Kerzen
//     3) an diesem Extrem eine WAAGERECHTE Linie zeichnen, die 4 Kerzen
//        (= 4 x 2H) nach rechts laeuft. Jede Linie steht fuer sich.
//
// Status: "ruhend" - diese Datei ist nicht mit der Webapp/dem Build verbunden.
//         Sie dient als Vorlage, die bei Bedarf in TradingView eingefuegt wird.
//
// -----------------------------------------------------------------------------
// ARCHITEKTUR / VERBINDLICHE SPEZIFIKATION  (Stand: 2026-06-26)
// -----------------------------------------------------------------------------
//   1) STARTZEITPUNKT
//      Der Nutzer waehlt per Chart-Klick (input.time, confirm=true) den Punkt,
//      ab dem ueberhaupt ausgewertet wird. Vor dem Startzeitpunkt: nichts.
//
//   2) GRUND-RECHEN-ZEITEINHEIT = 2H  (Heikin Ashi)
//      Die gesamte Logik wird AUSSCHLIESSLICH auf dem 2H-HA-Frame gerechnet,
//      ab dem Startzeitpunkt - unabhaengig von der Chart-Zeiteinheit.
//
//   3) VISUALISIERUNG AUF ALLEN ZEITEINHEITEN
//      Zeit-basiert gezeichnet (xloc.bar_time) -> korrekte Position auf jeder TF.
//
//   WICHTIG ZUR BERECHNUNG (Lehre aus einem Bug):
//      Der History-Operator [1] INNERHALB von request.security ist mit
//      lookahead_off NICHT zuverlaessig (kann sich auf dieselbe statt auf die
//      vorherige Kerze aufloesen -> Extrem fiel faelschlich auf das High der
//      roten Kerze zusammen). Deshalb holen wir per request.security nur die
//      ROHEN 2H-Werte und merken uns die letzten beiden ABGESCHLOSSENEN
//      2H-Kerzen explizit in var-Variablen auf der Chart-Seite. So ist
//      "vorherige Kerze" eindeutig und das Extrem korrekt.
//
//   BEKANNTE GRENZE: Voll praezise auf Chart-Zeiteinheiten <= 2H.
// =============================================================================

indicator("Stimmungswechsel 2H (HA)", overlay = true, max_lines_count = 500, max_labels_count = 500)

// -----------------------------------------------------------------------------
// Eingaben
// -----------------------------------------------------------------------------
startTime = input.time(timestamp("2024-01-01 00:00 +0000"), "Startzeitpunkt", confirm = true)

showStartMarker = input.bool(true,  "Startpunkt markieren",                 group = "Optik")
lineLenBars     = input.int(4,      "Linienlaenge (in 2H-Kerzen)", minval = 1, group = "Optik")
lineW           = input.int(2,      "Linienstaerke",      minval = 1, maxval = 5, group = "Optik")
colBull         = input.color(#2962ff, "Farbe bullischer Wechsel (blau)",   group = "Optik")
colBear         = input.color(#d50000, "Farbe bearischer Wechsel (rot)",    group = "Optik")
showDebug       = input.bool(false, "Debug-Label (Extreme je Wechsel)",     group = "Debug")

// -----------------------------------------------------------------------------
// Startpunkt-Marker (auf der jeweiligen Chart-Zeiteinheit)
// -----------------------------------------------------------------------------
isStartBar = time >= startTime and time[1] < startTime
if showStartMarker and isStartBar
    line.new(bar_index, low, bar_index, high, extend = extend.both, color = color.new(color.orange, 0), width = 1)
    label.new(bar_index, high, "Start", style = label.style_label_down, color = color.orange, textcolor = color.white, yloc = yloc.abovebar)

// -----------------------------------------------------------------------------
// Rohe 2H-Heikin-Ashi-Werte holen (NUR aktuelle Bar-Werte, kein [1] in security!)
// -----------------------------------------------------------------------------
ha2h = ticker.heikinashi(syminfo.tickerid)
[o2, c2, h2, l2, t2] = request.security(ha2h, "120",
     [open, close, high, low, time],
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

// -----------------------------------------------------------------------------
// Letzte beide ABGESCHLOSSENEN 2H-Kerzen explizit mitfuehren
//   last* = die zuletzt abgeschlossene 2H-Kerze
//   prev* = die 2H-Kerze davor
// -----------------------------------------------------------------------------
var float lastOpen  = na
var float lastClose = na
var float lastHigh  = na
var float lastLow   = na
var int   lastTime  = na
var float prevOpen  = na
var float prevClose = na
var float prevHigh  = na
var float prevLow   = na
var int   prevTime  = na

// Erste Chart-Kerze einer neuen 2H-Kerze -> die vorherige Chart-Kerze war die
// letzte Teil-Kerze der gerade ABGESCHLOSSENEN 2H-Kerze. Deren Endwerte holen
// wir per [1] auf CHART-Ebene (zuverlaessig, anders als [1] in der security).
isNew2H = not na(t2) and (na(t2[1]) or t2 != t2[1])

ms2H = 120 * 60 * 1000  // Millisekunden je 2H-Kerze

if isNew2H
    // Schieberegister: bisher "last" wird zu "prev"
    prevOpen  := lastOpen
    prevClose := lastClose
    prevHigh  := lastHigh
    prevLow   := lastLow
    prevTime  := lastTime
    // soeben abgeschlossene 2H-Kerze uebernehmen (Endwerte = Wert der letzten Teil-Kerze)
    lastOpen  := o2[1]
    lastClose := c2[1]
    lastHigh  := h2[1]
    lastLow   := l2[1]
    lastTime  := t2[1]

    // Farben der beiden abgeschlossenen Kerzen bestimmen
    lastRed  = not na(lastClose) and lastClose < lastOpen
    lastBlue = not na(lastClose) and lastClose > lastOpen
    prevRed  = not na(prevClose) and prevClose < prevOpen
    prevBlue = not na(prevClose) and prevClose > prevOpen

    canEval = not na(prevTime) and not na(lastTime) and lastTime >= startTime

    // BEARISCHER Wechsel: ROT folgt auf BLAU -> Extrem = hoeheres High beider Kerzen
    if canEval and lastRed and prevBlue
        ext = math.max(lastHigh, prevHigh)
        line.new(x1 = lastTime, y1 = ext, x2 = lastTime + lineLenBars * ms2H, y2 = ext,
                  xloc = xloc.bar_time, color = colBear, width = lineW)
        if showDebug
            label.new(lastTime, ext, xloc = xloc.bar_time, yloc = yloc.price,
                  text = "BEAR ext=" + str.tostring(ext, format.mintick) +
                         "\nrot H=" + str.tostring(lastHigh, format.mintick) +
                         "  blau H=" + str.tostring(prevHigh, format.mintick),
                  style = label.style_label_down, color = colBear, textcolor = color.white, size = size.small)

    // BULLISCHER Wechsel: BLAU folgt auf ROT -> Extrem = tieferes Low beider Kerzen
    if canEval and lastBlue and prevRed
        ext = math.min(lastLow, prevLow)
        line.new(x1 = lastTime, y1 = ext, x2 = lastTime + lineLenBars * ms2H, y2 = ext,
                  xloc = xloc.bar_time, color = colBull, width = lineW)
        if showDebug
            label.new(lastTime, ext, xloc = xloc.bar_time, yloc = yloc.price,
                  text = "BULL ext=" + str.tostring(ext, format.mintick) +
                         "\nblau L=" + str.tostring(lastLow, format.mintick) +
                         "  rot L=" + str.tostring(prevLow, format.mintick),
                  style = label.style_label_up, color = colBull, textcolor = color.white, size = size.small)
